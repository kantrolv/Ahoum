# Copy to `.env` and override any default from src/facet_eval/config.py.
# `.env` is gitignored (local only); this `.env.example` is the committed template.
# Precedence: real environment variable > .env > config.py default.

# --- Scoring LLM (Ollama) ---
# 3B by default (fits 8 GB without swapping). Override to the 7B for higher
# quality on bigger hardware — that's the only change needed:
#   OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M
OLLAMA_MODEL=qwen2.5:3b-instruct-q4_K_M
OLLAMA_HOST=http://localhost:11434

# --- Embeddings ---
EMBED_MODEL=BAAI/bge-small-en-v1.5

# --- Router / scorer knobs ---
ROUTER_TOP_K=30
ROUTER_SAFETY_FLOOR=12
SCORE_BATCH_SIZE=12
SCORE_ALL_FACETS=false
